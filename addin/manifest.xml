<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0" xmlns:mailappor="http://schemas.microsoft.com/office/mailappversionoverrides/1.0" xsi:type="MailApp">
<Id>a1b2c3d4-e5f6-7890-abcd-ef1234567890</Id>
<Version>1.3.0</Version>
<ProviderName>APeX</ProviderName>
<DefaultLocale>en-US</DefaultLocale>
<DisplayName DefaultValue="APeX Capture"/>
<Description DefaultValue="Capture emails and meetings directly into APeX initiatives"/>
<IconUrl DefaultValue="https://aiagentpfund.github.io/APEX/addin/icon-64.png"/>
<HighResolutionIconUrl DefaultValue="https://aiagentpfund.github.io/APEX/addin/icon-128.png"/>
<SupportUrl DefaultValue="https://aiagentpfund.github.io/APEX/"/>
<AppDomains>
<AppDomain>https://aiagentpfund.github.io</AppDomain>
</AppDomains>
<Hosts>
<Host Name="Mailbox"/>
</Hosts>
<Requirements>
<Sets>
<Set Name="Mailbox" MinVersion="1.1"/>
</Sets>
</Requirements>
<FormSettings>
<Form xsi:type="ItemRead">
<DesktopSettings>
<SourceLocation DefaultValue="https://aiagentpfund.github.io/APEX/addin/taskpane.html"/>
<RequestedHeight>550</RequestedHeight>
</DesktopSettings>
</Form>
</FormSettings>
<Permissions>ReadItem</Permissions>
<Rule xsi:type="RuleCollection" Mode="Or">
<Rule xsi:type="ItemIs" ItemType="Message" FormType="Read"/>
<Rule xsi:type="ItemIs" ItemType="Appointment" FormType="Read"/>
</Rule>
<VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides" xsi:type="VersionOverridesV1_0">
<Requirements>
<bt:Sets>
<bt:Set Name="Mailbox" MinVersion="1.3"/>
</bt:Sets>
</Requirements>
<Hosts>
<Host xsi:type="MailHost">
<DesktopFormFactor>
<FunctionFile resid="Commands.Url"/>
<ExtensionPoint xsi:type="MessageReadCommandSurface">
<OfficeTab id="TabDefault">
<Group id="apex.group">
<Label resid="GroupLabel"/>
<Control xsi:type="Button" id="apex.taskpane.button">
<Label resid="TaskpaneButton.Label"/>
<Supertip>
<Title resid="TaskpaneButton.Label"/>
<Description resid="TaskpaneButton.Tooltip"/>
</Supertip>
<Icon>
<bt:Image size="16" resid="Icon.16x16"/>
<bt:Image size="32" resid="Icon.32x32"/>
<bt:Image size="64" resid="Icon.64x64"/>
</Icon>
<Action xsi:type="ShowTaskpane">
<TaskpaneId>ButtonId1</TaskpaneId>
<SourceLocation resid="Taskpane.Url"/>
</Action>
</Control>
</Group>
</OfficeTab>
</ExtensionPoint>
<ExtensionPoint xsi:type="AppointmentAttendeeCommandSurface">
<OfficeTab id="TabDefault">
<Group id="apex.group.appt">
<Label resid="GroupLabel"/>
<Control xsi:type="Button" id="apex.taskpane.button.appt">
<Label resid="TaskpaneButton.Label"/>
<Supertip>
<Title resid="TaskpaneButton.Label"/>
<Description resid="TaskpaneButton.Tooltip"/>
</Supertip>
<Icon>
<bt:Image size="16" resid="Icon.16x16"/>
<bt:Image size="32" resid="Icon.32x32"/>
<bt:Image size="64" resid="Icon.64x64"/>
</Icon>
<Action xsi:type="ShowTaskpane">
<TaskpaneId>ButtonId2</TaskpaneId>
<SourceLocation resid="Taskpane.Url"/>
</Action>
</Control>
</Group>
</OfficeTab>
</ExtensionPoint>
</DesktopFormFactor>
</Host>
</Hosts>
<Resources>
<bt:Images>
<bt:Image id="Icon.16x16" DefaultValue="https://aiagentpfund.github.io/APEX/addin/icon-16.png"/>
<bt:Image id="Icon.32x32" DefaultValue="https://aiagentpfund.github.io/APEX/addin/icon-32.png"/>
<bt:Image id="Icon.64x64" DefaultValue="https://aiagentpfund.github.io/APEX/addin/icon-64.png"/>
<bt:Image id="Icon.128x128" DefaultValue="https://aiagentpfund.github.io/APEX/addin/icon-128.png"/>
</bt:Images>
<bt:Urls>
<bt:Url id="Commands.Url" DefaultValue="https://aiagentpfund.github.io/APEX/addin/commands.html"/>
<bt:Url id="Taskpane.Url" DefaultValue="https://aiagentpfund.github.io/APEX/addin/taskpane.html"/>
</bt:Urls>
<bt:ShortStrings>
<bt:String id="GroupLabel" DefaultValue="APeX"/>
<bt:String id="TaskpaneButton.Label" DefaultValue="Send to APeX"/>
</bt:ShortStrings>
<bt:LongStrings>
<bt:String id="TaskpaneButton.Tooltip" DefaultValue="Capture this email or meeting as an artifact in APeX"/>
</bt:LongStrings>
</Resources>
</VersionOverrides>
</OfficeApp>
